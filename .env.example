# ============================================================
#  excalidraw-storage-backend — exemplo de variáveis
#  Copie para `.env` e ajuste. NUNCA commite o `.env` real.
# ============================================================

NODE_ENV=production
PORT=8080

# Prefixo global das rotas. Frontend usa NEXT_PUBLIC_BACKEND_URL=.../api/v2
GLOBAL_PREFIX=api/v2

# ------------------------------------------------------------
# Banco (Prisma + Postgres)
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:senha@host:5432/excalidraw?schema=public

# ------------------------------------------------------------
# Auth
# ------------------------------------------------------------
# Gere com: openssl rand -hex 64
JWT_SECRET=troque-este-segredo-em-producao

# Em produção (HTTPS) → true. Em dev local (http) → false.
COOKIE_SECURE=true

# Domínio do cookie de sessão. Use ".dominio.com" (com ponto inicial)
# pra que o cookie seja válido em frontend.dominio.com E api.dominio.com.
# Deixe vazio em dev local (cookie fica preso ao host atual).
COOKIE_DOMAIN=.leosgarbi.com.br

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# URLs do frontend (separe múltiplas por vírgula, sem barra final).
CORS_ORIGINS=https://excalidraw.leosgarbi.com.br

# ------------------------------------------------------------
# Limites
# ------------------------------------------------------------
BODY_LIMIT=50mb
