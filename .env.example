# ============================================================
#  excalidraw-storage-backend — exemplo de variáveis
#  Copie para `.env` e ajuste. NUNCA commite o `.env` real.
# ============================================================

# Ambiente Node
NODE_ENV=production

# Porta HTTP que o NestJS vai escutar
PORT=8080

# Prefixo global das rotas. Padrão do app: /api/v2
# Mantém compatível com o frontend (NEXT_PUBLIC_BACKEND_URL=.../api)
GLOBAL_PREFIX=/api/v2

# Nível de log do Nest: log | error | warn | debug | verbose
LOG_LEVEL=log

# ------------------------------------------------------------
# Persistência (Keyv) — escolha UMA das opções abaixo.
# Sem STORAGE_URI o app roda em memória (perde tudo no restart).
# ------------------------------------------------------------

# Redis (recomendado p/ produção leve)
STORAGE_URI=redis://localhost:6379

# PostgreSQL
# STORAGE_URI=postgresql://user:password@localhost:5432/excalidraw

# MySQL / MariaDB
# STORAGE_URI=mysql://user:password@localhost:3306/excalidraw

# MongoDB
# STORAGE_URI=mongodb://user:password@localhost:27017/excalidraw

# SQLite (arquivo local — só p/ dev / single-node)
# STORAGE_URI=sqlite://./data/storage.sqlite
